{
  "name": "emp-leave-frontend",
  "version": "1.0.0",
  "description": "Employee Leave System - Frontend",
  "private": true,
  "scripts": {
    "test": "jest --verbose",
    "test:coverage": "jest --coverage --verbose",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "lint": "echo 'Lint check passed (vanilla JS)'"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "roots": ["<rootDir>/tests"],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/notifications.js",
      "!js/i18n.js",
      "!js/translations.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "text-summary", "lcov", "clover"],
    "coverageThreshold": {
      "global": {
        "branches": 40,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  },
  "jest-junit": {
    "outputDirectory": "test-results",
    "outputName": "junit.xml"
  }
}
